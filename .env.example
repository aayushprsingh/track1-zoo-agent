# ============================================================
# Zoo Guide Agent — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored — NEVER commit actual secrets.
# ============================================================

# --- Required ---
# Your Google Cloud Project ID (found at console.cloud.google.com)
PROJECT_ID=your-gcp-project-id

# Your Google Cloud Project Number (found in IAM > Settings)
PROJECT_NUMBER=123456789012

# Service Account name (you create this during setup)
SA_NAME=zoo-cr-service

# Full service account email (auto-generated from SA_NAME + PROJECT_ID)
SERVICE_ACCOUNT=zoo-cr-service@your-gcp-project-id.iam.gserviceaccount.com

# --- Model Config (defaults work fine) ---
MODEL=gemini-2.5-flash

# --- Optional ---
# Wikipedia language (default: en)
WIKIPEDIA_LANG=en

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Agent personality (keep it short — this prepends the system prompt)
AGENT_PERSONA="You are a friendly and knowledgeable zoo tour guide."
